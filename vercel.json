{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 60
      }
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "app.py"
    },
    {
      "src": "/(style\\.css|app\\.js|logo\\.png|forensics_art\\.png)",
      "dest": "app.py"
    },
    {
      "src": "/frames/(.*)",
      "dest": "/frontend/frames/$1"
    },
    {
      "src": "/",
      "dest": "app.py"
    }
  ]
}
